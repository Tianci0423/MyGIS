<Window x:Class="MyGIS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        xmlns:controls="clr-namespace:MyGIS.Controls"
        mc:Ignorable="d"
        Title="MyGIS" Height="760" Width="1220" MinHeight="620" MinWidth="980"
        Background="#EEF2F6" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Microsoft YaHei UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <SolidColorBrush x:Key="ChromeBg" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="PanelBg" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#D9E2EC"/>
        <SolidColorBrush x:Key="TextMain" Color="#253243"/>
        <SolidColorBrush x:Key="TextMuted" Color="#65758B"/>
        <SolidColorBrush x:Key="Accent" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#E7F0FF"/>

        <Style x:Key="TopMenuItem" TargetType="MenuItem">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EDF4FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#BFD4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DCEAFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#8FB4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EDF4FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#BFD4FF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DCEAFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6EA0FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconPath" TargetType="Path">
            <Setter Property="Stroke" Value="#334155"/>
            <Setter Property="StrokeThickness" Value="1.8"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style x:Key="ToolLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="ToolSep" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#B8C2CE"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <ControlTemplate x:Key="ExpandToggle" TargetType="ToggleButton">
            <Border Background="Transparent" Width="18" Height="18">
                <Path x:Name="Arrow" Stroke="#64748B" StrokeThickness="1.8"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M6,4 L11,9 L6,14"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Arrow" Property="Data" Value="M4,7 L9,12 L14,7"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="TextBox" x:Key="SearchBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="28,5,8,5"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D6E0EA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Height="34" Background="{StaticResource ChromeBg}"
              BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1">
            <MenuItem Header="文件" Style="{StaticResource TopMenuItem}">
                <MenuItem Header="新建" Click="OnFileNew"/>
                <Separator/>
                <MenuItem Header="打开项目" Click="OnMenuOpen"/>
                <MenuItem Header="保存项目" Click="OnMenuSave"/>
            </MenuItem>
            <MenuItem Header="分析" Style="{StaticResource TopMenuItem}">
                <MenuItem Header="波段计算器" Click="OnBandCalculator"/>
            </MenuItem>
            <MenuItem Header="工具" Style="{StaticResource TopMenuItem}">
                <MenuItem Header="影像配准" Click="OnRegistration"/>
                <MenuItem Header="批量影像配准" Click="OnBatchRegistration"/>
                <Separator/>
                <MenuItem Header="影像融合" Click="OnImageFusion"/>
                <MenuItem Header="批量影像融合" Click="OnBatchImageFusion"/>
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="0,0,0,1" Padding="8,5">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource ToolButton}" ToolTip="新建" Click="OnFileNew">
                        <StackPanel>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                                <Path Stroke="#2F4058" StrokeThickness="1.8" StrokeLineJoin="Round" Fill="#FFFFFF"
                                      Data="M6,3.5 H15 L19,7.5 V20.5 H6 Z"/>
                                <Path Stroke="#2F4058" StrokeThickness="1.8" StrokeLineJoin="Round" Fill="#EAF2FF"
                                      Data="M15,3.5 V7.5 H19"/>
                            </Canvas>
                            <TextBlock Style="{StaticResource ToolLabel}" Text="新建"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButton}" ToolTip="打开项目" Click="OnOpenFileClick">
                        <StackPanel>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                                <Path Stroke="#C28A1A" StrokeThickness="1.6" StrokeLineJoin="Round" Fill="#FFE8A3"
                                      Data="M3.5,8 H9.2 L11,10 H20.5 V18.8 H3.5 Z"/>
                                <Path Stroke="#C28A1A" StrokeThickness="1.6" StrokeLineJoin="Round" Fill="#FFD35A"
                                      Data="M3.5,8 V6 H9.5 L11.2,8 Z"/>
                            </Canvas>
                            <TextBlock Style="{StaticResource ToolLabel}" Text="打开"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButton}" ToolTip="添加数据" Click="OnAddDataClick">
                        <StackPanel>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                                <Path Stroke="#5E8BB8" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="#DCEBFF"
                                      Data="M12,3.8 L19,7.8 L12,11.8 L5,7.8 Z"/>
                                <Path Stroke="#C28A1A" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="#FFE08A"
                                      Data="M5,7.8 V15.7 L12,20 V11.8 Z"/>
                                <Path Stroke="#2563EB" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="#A8D4FF"
                                      Data="M19,7.8 V15.7 L12,20 V11.8 Z"/>
                                <Path Stroke="#2F4058" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M12,6.4 V9.6 M10.4,8 H13.6"/>
                            </Canvas>
                            <TextBlock Style="{StaticResource ToolLabel}" Text="添加数据"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButton}" ToolTip="保存项目" Click="OnMenuSave">
                        <StackPanel>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                                <Path Stroke="#2F4058" StrokeThickness="1.7" StrokeLineJoin="Round" Fill="#E9F2FF"
                                      Data="M5,4 H16 L20,8 V20 H5 Z"/>
                                <Rectangle Canvas.Left="8" Canvas.Top="5" Width="8" Height="6" RadiusX="1" RadiusY="1"
                                           Stroke="#2563EB" StrokeThickness="1.4" Fill="#8EC5FF"/>
                                <Path Stroke="#2F4058" StrokeThickness="1.6" StrokeLineJoin="Round" Fill="#FFFFFF"
                                      Data="M8,15 H17 V20 H8 Z"/>
                            </Canvas>
                            <TextBlock Style="{StaticResource ToolLabel}" Text="保存"/>
                        </StackPanel>
                    </Button>

                    <Border Style="{StaticResource ToolSep}"/>

                    <ToggleButton x:Name="PanBtn" Style="{StaticResource ToolToggle}" IsChecked="True"
                                  ToolTip="平移" Click="OnPanClick">
                        <StackPanel>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                                <Path Stroke="#5F84B8" StrokeThickness="1.75" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="#DDEBFF"
                                      Data="M7.9,12.3 V8.5 A1.35,1.35 0 0,1 10.6,8.5 V11.7
                                            M10.6,11.7 V6.6 A1.35,1.35 0 0,1 13.3,6.6 V11.6
                                            M13.3,11.6 V7.6 A1.35,1.35 0 0,1 16,7.6 V12.1
                                            M16,12.1 V9.8 A1.35,1.35 0 0,1 18.7,9.8 V14
                                            C18.7,17.4 16.7,20.1 13.7,20.1 H11
                                            C9.4,20.1 8.1,19.1 7.3,17.7 L5.4,14.5
                                            A1.15,1.15 0 0,1 7.2,12.9 L7.9,13.7"/>
                                <Path Stroke="#5F84B8" StrokeThickness="1.2" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Data="M10.6,11.2 V12.5 M13.3,11.1 V12.4 M16,11.6 V12.8"/>
                            </Canvas>
                            <TextBlock Style="{StaticResource ToolLabel}" Text="平移"/>
                        </StackPanel>
                    </ToggleButton>
                    <Button Style="{StaticResource ToolButton}" ToolTip="放大" Click="OnZoomInClick">
                        <StackPanel>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                                <Path Stroke="#2F4058" StrokeThickness="1.9" StrokeLineJoin="Round" Fill="#F8FBFF"
                                      Data="M10.5,4 A6.2,6.2 0 1,0 10.5,16.4 A6.2,6.2 0 1,0 10.5,4 Z"/>
                                <Path Stroke="#2563EB" StrokeThickness="1.8" StrokeStartLineCap="Round" Data="M10.5,7.6 V12.8 M7.9,10.2 H13.1"/>
                                <Path Stroke="#2F4058" StrokeThickness="1.9" StrokeStartLineCap="Round" Data="M15.2,15.2 L20.5,20.5"/>
                            </Canvas>
                            <TextBlock Style="{StaticResource ToolLabel}" Text="放大"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButton}" ToolTip="缩小" Click="OnZoomOutClick">
                        <StackPanel>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                                <Path Stroke="#2F4058" StrokeThickness="1.9" StrokeLineJoin="Round" Fill="#F8FBFF"
                                      Data="M10.5,4 A6.2,6.2 0 1,0 10.5,16.4 A6.2,6.2 0 1,0 10.5,4 Z"/>
                                <Path Stroke="#2563EB" StrokeThickness="1.8" StrokeStartLineCap="Round" Data="M7.9,10.2 H13.1"/>
                                <Path Stroke="#2F4058" StrokeThickness="1.9" StrokeStartLineCap="Round" Data="M15.2,15.2 L20.5,20.5"/>
                            </Canvas>
                            <TextBlock Style="{StaticResource ToolLabel}" Text="缩小"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButton}" ToolTip="全图显示" Click="OnFullExtentClick">
                        <StackPanel>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                                <Path Stroke="#2F4058" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" Data="M4,9 V4 H9 M15,4 H20 V9 M20,15 V20 H15 M9,20 H4 V15"/>
                                <Rectangle Canvas.Left="8" Canvas.Top="8" Width="8" Height="8" Stroke="#2563EB"
                                           StrokeThickness="1.5" Fill="#F8FBFF"/>
                            </Canvas>
                            <TextBlock Style="{StaticResource ToolLabel}" Text="全图"/>
                        </StackPanel>
                    </Button>

                    <Border Style="{StaticResource ToolSep}"/>

                    <ToggleButton x:Name="IdentifyBtn" Style="{StaticResource ToolToggle}"
                                  ToolTip="识别像素值" Click="OnIdentifyClick">
                        <StackPanel>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                                <Ellipse Canvas.Left="9" Canvas.Top="9" Width="6" Height="6"
                                         Stroke="#2F4058" StrokeThickness="1.7" Fill="#FFFFFF"/>
                                <Path Stroke="#2F4058" StrokeThickness="1.8" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Data="M12,4 V7 M12,17 V20 M4,12 H7 M17,12 H20"/>
                                <Path Stroke="#C28A1A" StrokeThickness="1.7" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Data="M6.4,6.4 L8.5,8.5 M17.6,6.4 L15.5,8.5 M6.4,17.6 L8.5,15.5 M17.6,17.6 L15.5,15.5"/>
                            </Canvas>
                            <TextBlock Style="{StaticResource ToolLabel}" Text="识别"/>
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="285" MinWidth="230"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"
                    CornerRadius="0" Margin="8,8,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="12,10,10,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="图层" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMain}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="12,0,12,9">
                        <TextBox x:Name="LayerSearchBox" Style="{StaticResource SearchBox}"
                                 TextChanged="OnLayerSearchTextChanged"/>
                        <Path Style="{StaticResource IconPath}" Width="14" Height="14"
                              HorizontalAlignment="Left" VerticalAlignment="Center"
                              Margin="9,0,0,0" Stroke="#94A3B8"
                              Data="M6,2 A4,4 0 1,0 6,10 A4,4 0 1,0 6,2 Z M9,9 L13,13"/>
                        <TextBlock Text="搜索图层" Foreground="#9AA8B8" FontSize="12"
                                   Margin="30,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=LayerSearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ListBox x:Name="LayerListBox" Grid.Row="2" Margin="8,0,8,8"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="False"
                             AllowDrop="True" SelectionMode="Extended"
                             PreviewMouseRightButtonDown="OnLayerListRightClick"
                             PreviewMouseMove="OnLayerListPreviewMouseMove"
                             Drop="OnLayerListDrop">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#F3F7FB" CornerRadius="4" Padding="8,5" Margin="4,7,4,3">
                                            <TextBlock Text="{Binding Name}" Foreground="#486179"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="4,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="Transparent" BorderThickness="1"
                                                    CornerRadius="4" Padding="0">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#F1F6FD"/>
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#D5E5FA"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#E4F0FF"/>
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#8EBBFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,5" MinWidth="0" ClipToBounds="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="ExpandBtn" Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                  Width="18" Height="18" Margin="0,1,4,0"
                                                  VerticalAlignment="Top"
                                                  Visibility="{Binding HasLegend, Converter={StaticResource BoolToVis}}"
                                                  Template="{StaticResource ExpandToggle}"/>

                                    <StackPanel Grid.Column="1" MinWidth="0">
                                        <Grid MinWidth="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsVisible}"
                                                      VerticalAlignment="Center" Margin="0,0,7,0"
                                                      PreviewMouseLeftButtonDown="OnLayerCheckBoxPreviewMouseLeftButtonDown"
                                                      Click="OnLayerVisibilityChanged"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextMain}"
                                                       FontSize="12.5" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <TextBlock Text="{Binding LayerTypeLabel}" Foreground="{StaticResource TextMuted}"
                                                   FontSize="11.5" Margin="22,2,0,0"/>

                                        <StackPanel Margin="22,8,0,2"
                                                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Visibility="{Binding ShowGray, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="值" FontSize="11.5" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                                <DockPanel>
                                                    <Rectangle Width="14" Height="56" RadiusX="3" RadiusY="3"
                                                               Fill="{Binding Legend.RampBrush}" Margin="0,0,8,0"/>
                                                    <StackPanel>
                                                        <TextBlock FontSize="11.5" Foreground="#526170"
                                                                   Text="{Binding Legend.MaxValue, StringFormat='高：{0:F2}'}"/>
                                                        <TextBlock FontSize="11.5" Foreground="#526170" Margin="0,29,0,0"
                                                                   Text="{Binding Legend.MinValue, StringFormat='低：{0:F2}'}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </StackPanel>

                                            <StackPanel Visibility="{Binding ShowRgb, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="RGB" FontSize="11.5" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="14"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Rectangle Width="10" Height="10" Fill="#EF2A2A" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Legend.RedBand}" Foreground="{StaticResource TextMain}" FontSize="11.5" Margin="4,0,0,0"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="14"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Rectangle Width="10" Height="10" Fill="#28C840" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Legend.GreenBand}" Foreground="{StaticResource TextMain}" FontSize="11.5" Margin="4,0,0,0"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="14"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Rectangle Width="10" Height="10" Fill="#2F6BFF" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Legend.BlueBand}" Foreground="{StaticResource TextMain}" FontSize="11.5" Margin="4,0,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" Background="Transparent"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ShowsPreview="True"/>

            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                <Grid Margin="0,8,8,8">
                    <mapsui:MapControl x:Name="MapControl"/>
                    <controls:GpuRasterMapControl x:Name="GpuRasterMap"/>
                    <Canvas x:Name="IdentifyMarkerCanvas" IsHitTestVisible="False">
                        <Ellipse x:Name="IdentifyDot" Width="10" Height="10"
                                 Fill="#EF4444" Stroke="#FFFFFF" StrokeThickness="1.5"
                                 Visibility="Collapsed" Canvas.Left="0" Canvas.Top="0"/>
                    </Canvas>
                    <Border x:Name="ProgressPanel" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1"
                            CornerRadius="8" Padding="12,8" Margin="0,0,14,12"
                            Visibility="Collapsed" MinWidth="250">
                        <StackPanel>
                            <TextBlock x:Name="ProgressLabel" Text="处理中..." FontSize="12"
                                       Foreground="{StaticResource TextMain}" Margin="0,0,0,6"
                                       Width="220" TextTrimming="CharacterEllipsis"/>
                            <ProgressBar x:Name="ProgressBar" Height="6" Width="220"
                                         IsIndeterminate="False" Minimum="0" Maximum="100"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="0,1,0,0" Padding="12,0" Height="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CoordText" Grid.Column="0" Text="-" FontSize="11.5"
                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                <TextBlock x:Name="CrsStatusText" Grid.Column="2" Text="-" FontSize="11.5"
                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="18,0,0,0"/>
                <TextBlock x:Name="StatusText" Grid.Column="3" Text="就绪" FontSize="11.5"
                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="18,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
