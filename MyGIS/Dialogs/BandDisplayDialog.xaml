<Window x:Class="MyGIS.Dialogs.BandDisplayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="显示设置" Width="360" SizeToContent="Height" MinWidth="320" MinHeight="220"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#F8F8F8">
    <Window.Resources>
        <DataTemplate x:Key="RampTemplate">
            <Border Height="20" Width="200" HorizontalAlignment="Stretch"
                    CornerRadius="2" Margin="2,1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{Binding C0}" Offset="0"/>
                        <GradientStop Color="{Binding C1}" Offset="0.25"/>
                        <GradientStop Color="{Binding C2}" Offset="0.5"/>
                        <GradientStop Color="{Binding C3}" Offset="0.75"/>
                        <GradientStop Color="{Binding C4}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 拉伸 -->
        <GroupBox Grid.Row="0" Header="拉伸" Padding="10" Margin="0,0,0,10">
            <ComboBox x:Name="StretchCombo" SelectedIndex="0">
                <ComboBoxItem Content="百分比截断" Tag="PercentClip"/>
                <ComboBoxItem Content="无" Tag="None"/>
                <ComboBoxItem Content="标准差 (2σ)" Tag="StdDev"/>
                <ComboBoxItem Content="直方图均衡化" Tag="HistEq"/>
                <ComboBoxItem Content="最值" Tag="MinMax"/>
                <ComboBoxItem Content="S 型 (Sigmoid)" Tag="Sigmoid"/>
            </ComboBox>
        </GroupBox>

        <!-- 色带 (仅单波段) -->
        <GroupBox x:Name="ColorRampGroup" Grid.Row="1" Header="色带" Padding="10" Margin="0,0,0,10">
            <ComboBox x:Name="ColorRampCombo" SelectedIndex="0" MaxDropDownHeight="320"
                      ItemTemplate="{StaticResource RampTemplate}"/>
        </GroupBox>

        <!-- RGB 合成 -->
        <GroupBox x:Name="RgbGroup" Grid.Row="2" Header="RGB 合成" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="R:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#E53E3E"/>
                    <ComboBox x:Name="RedBandCombo" Grid.Column="1"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="G:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#38A169"/>
                    <ComboBox x:Name="GreenBandCombo" Grid.Column="1"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="B:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#3182CE"/>
                    <ComboBox x:Name="BlueBandCombo" Grid.Column="1"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="应用" Width="70" Height="28" Click="OnApplyClick"
                    Background="#2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="关闭" Width="70" Height="28" Click="OnCancelClick" Margin="8,0,0,0"
                    Background="#E5E7EB" Foreground="#333" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
