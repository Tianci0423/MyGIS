<Window x:Class="MyGIS.Dialogs.BatchFusionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量影像融合" MinWidth="760" MinHeight="540" Width="900" Height="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="按任务队列依次融合多对已配准到同一网格的 MS/PAN 影像。批量融合默认顺序执行，避免多个推理进程同时占用 CUDA 显存和磁盘写入带宽。"
                   Foreground="#475569" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="76"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="76"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="MS 影像" VerticalAlignment="Center" Foreground="#334155"/>
            <ComboBox x:Name="MsBox" Grid.Column="1" Height="28"
                      IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                      DisplayMemberPath="Name" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="浏览" Height="28" Margin="8,0,0,0" Click="OnBrowseMs"/>

            <TextBlock Grid.Column="3" Text="PAN 影像" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#334155"/>
            <ComboBox x:Name="PanBox" Grid.Column="4" Height="28"
                      IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                      DisplayMemberPath="Name" VerticalContentAlignment="Center"/>
            <Button Grid.Column="5" Content="浏览" Height="28" Margin="8,0,0,0" Click="OnBrowsePan"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="76"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="输出目录" VerticalAlignment="Center" Foreground="#334155"/>
            <TextBox x:Name="OutputDirBox" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="浏览" Height="28" Margin="8,0,0,0" Click="OnBrowseOutputDir"/>
            <Button Grid.Column="3" Content="加入任务" Height="28" Margin="8,0,0,0" Click="OnAddTask"
                    Background="#2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="LoadAfterFusionBox" Content="完成后加载结果" Foreground="#334155" Margin="0,0,18,0"/>
                <CheckBox x:Name="ContinueOnErrorBox" Content="失败后继续下一项" IsChecked="True" Foreground="#334155"/>
            </StackPanel>

            <Button Grid.Column="1" Content="移除选中" Height="28" Width="86" Click="OnRemoveSelected"
                    Background="#E5E7EB" Foreground="#334155" BorderThickness="0" Cursor="Hand"/>
            <Button Grid.Column="2" Content="清空" Height="28" Width="64" Margin="8,0,0,0" Click="OnClearTasks"
                    Background="#E5E7EB" Foreground="#334155" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <DataGrid x:Name="TaskGrid" Grid.Row="4"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" SelectionMode="Extended" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" RowHeaderWidth="0"
                  Background="White" BorderBrush="#CBD5E1" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="46"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="MS" Binding="{Binding MsDisplay}" Width="*"/>
                <DataGridTextColumn Header="PAN" Binding="{Binding PanDisplay}" Width="*"/>
                <DataGridTextColumn Header="输出目录" Binding="{Binding OutputDir}" Width="1.3*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="SummaryText" Grid.Row="5" Margin="0,8,0,0"
                   Text="0 个任务" Foreground="#64748B" FontSize="12"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="开始批量融合" Width="112" Height="32" Click="OnRunClick"
                    Background="#2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Width="80" Height="32" Click="OnCancelClick" Margin="8,0,0,0"
                    Background="#E5E7EB" Foreground="#334155" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
