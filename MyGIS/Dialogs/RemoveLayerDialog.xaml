<Window x:Class="MyGIS.Dialogs.RemoveLayerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="移除图层" Width="480" Height="240" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8F8F8" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="MessageText" FontSize="13" Foreground="#333"
                   TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,4,0,0"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="DeleteBtn" Content="删除文件" Width="90" Height="30"
                    Click="OnDeleteClick" Margin="0,0,8,0"
                    Background="#EF4444" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="KeepBtn" Content="另存为..." Width="90" Height="30"
                    Click="OnKeepClick" Margin="0,0,8,0"
                    Background="#2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Width="70" Height="30" Click="OnCancelClick"
                    Background="#E5E7EB" Foreground="#333" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
