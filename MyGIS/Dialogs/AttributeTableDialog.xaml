<Window x:Class="MyGIS.Dialogs.AttributeTableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="属性表" Width="700" Height="450"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        MinWidth="400" MinHeight="250"
        Background="#F8F8F8">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="InfoText" Grid.Row="0" FontSize="11" Foreground="#888"
                   Margin="4,2,0,4" Text="—"/>
        <DataGrid x:Name="AttrGrid" Grid.Row="1" AutoGenerateColumns="True"
                  IsReadOnly="True" HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#E5E5E5"
                  VerticalGridLinesBrush="#D0D0D0"
                  BorderBrush="#DDD"
                  FontSize="11" RowHeaderWidth="36"
                  CanUserResizeColumns="True" CanUserReorderColumns="True"
                  CanUserSortColumns="True" SelectionMode="Extended"/>
        <TextBlock Grid.Row="2" x:Name="StatusText" FontSize="11" Foreground="#888"
                   Margin="4,4,0,2" Text="—"/>
    </Grid>
</Window>
