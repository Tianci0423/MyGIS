<Window x:Class="GeoVision.Dialogs.BandCalcDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="波段计算器" Width="440" Height="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8F8F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 源图层 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="源图层:" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
            <ComboBox x:Name="SourceLayerCombo" Grid.Column="1" Height="26" FontSize="11"
                      SelectionChanged="OnSourceLayerChanged"/>
        </Grid>

        <!-- 波段信息 -->
        <TextBlock x:Name="BandInfoText" Grid.Row="1" FontSize="11" Foreground="#888"
                   Margin="0,0,0,10" TextWrapping="Wrap"/>

        <!-- 公式 -->
        <GroupBox Grid.Row="2" Header="公式" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="FormulaBox" Height="28" FontSize="13" FontFamily="Consolas"
                         Text="(b4-b3)/(b4+b3)" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="1" FontSize="10" Foreground="#999" Margin="0,3,0,0"
                           Text="使用 b1, b2, b3... 表示各波段，支持 + - * / ( )"/>
            </Grid>
        </GroupBox>

        <!-- 预设 -->
        <GroupBox Grid.Row="3" Header="常用指数预设" Padding="10" Margin="0,0,0,8">
            <WrapPanel>
                <Button Content="NDVI" Width="70" Height="26" Margin="0,0,6,4"
                        Click="OnPresetClick" Tag="NDVI"
                        Background="#E8F5E9" Foreground="#2E7D32" BorderThickness="0" Cursor="Hand"/>
                <Button Content="NDWI" Width="70" Height="26" Margin="0,0,6,4"
                        Click="OnPresetClick" Tag="NDWI"
                        Background="#E3F2FD" Foreground="#1565C0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="EVI" Width="70" Height="26" Margin="0,0,6,4"
                        Click="OnPresetClick" Tag="EVI"
                        Background="#FFF3E0" Foreground="#E65100" BorderThickness="0" Cursor="Hand"/>
                <Button Content="NDBI" Width="70" Height="26" Margin="0,0,6,4"
                        Click="OnPresetClick" Tag="NDBI"
                        Background="#F3E5F5" Foreground="#7B1FA2" BorderThickness="0" Cursor="Hand"/>
                <Button Content="SAVI" Width="70" Height="26" Margin="0,0,6,4"
                        Click="OnPresetClick" Tag="SAVI"
                        Background="#E0F2F1" Foreground="#00695C" BorderThickness="0" Cursor="Hand"/>
            </WrapPanel>
        </GroupBox>

        <!-- 输出名称 -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="输出名称:" FontSize="12" Foreground="#555" VerticalAlignment="Center"/>
            <TextBox x:Name="OutputNameBox" Grid.Column="1" Height="26" FontSize="12"
                     Text="result" VerticalContentAlignment="Center"/>
        </Grid>

        <!-- 按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="计算" Width="80" Height="30" Click="OnComputeClick"
                    Background="#2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Width="80" Height="30" Click="OnCancelClick" Margin="8,0,0,0"
                    Background="#E5E7EB" Foreground="#333" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
