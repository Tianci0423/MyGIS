<Window x:Class="GeoVision.Dialogs.RasterClipDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="影像裁剪" Width="520" Height="300" MinWidth="460" MinHeight="280"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="输入影像" VerticalAlignment="Center" Foreground="#334155"/>
            <ComboBox x:Name="RasterCombo" Grid.Column="1" Height="28"
                      DisplayMemberPath="Name" SelectionChanged="OnRasterChanged"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="裁剪方式" VerticalAlignment="Center" Foreground="#334155"/>
            <ComboBox x:Name="ModeCombo" Grid.Column="1" Height="28" SelectedIndex="0"
                      SelectionChanged="OnModeChanged">
                <ComboBoxItem Content="当前视图范围" Tag="CurrentView"/>
                <ComboBoxItem Content="地图矩形框选" Tag="Rectangle"/>
                <ComboBoxItem Content="矢量边界" Tag="VectorBoundary"/>
            </ComboBox>
        </Grid>

        <Grid x:Name="VectorRow" Grid.Row="2" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="边界图层" VerticalAlignment="Center" Foreground="#334155"/>
            <ComboBox x:Name="VectorCombo" Grid.Column="1" Height="28" DisplayMemberPath="Name"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="76"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="输出文件" VerticalAlignment="Center" Foreground="#334155"/>
            <TextBox x:Name="OutputBox" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="浏览" Height="28" Margin="8,0,0,0" Click="OnBrowseOutput"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <CheckBox x:Name="LoadResultBox" Content="完成后加载结果" IsChecked="True"
                      VerticalAlignment="Center" Margin="0,0,18,0"/>
            <Button Content="开始裁剪" Width="88" Height="30" Click="OnRunClick"
                    Background="#2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Width="72" Height="30" Click="OnCancelClick" Margin="8,0,0,0"
                    Background="#E5E7EB" Foreground="#334155" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
