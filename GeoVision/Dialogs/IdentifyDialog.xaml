<Window x:Class="GeoVision.Dialogs.IdentifyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="识别结果" Width="340" Height="420"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F8F8F8">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 位置信息 -->
        <GroupBox Grid.Row="0" Header="位置" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="经度:" FontSize="12" Foreground="#555"
                           VerticalAlignment="Center" Margin="0,0,8,0" Grid.Row="0"/>
                <TextBlock x:Name="LonText" Grid.Column="1" Grid.Row="0"
                           FontSize="12" Foreground="#333" VerticalAlignment="Center" Text="—"/>
                <TextBlock Text="纬度:" FontSize="12" Foreground="#555"
                           VerticalAlignment="Center" Margin="0,0,8,0" Grid.Row="1"/>
                <TextBlock x:Name="LatText" Grid.Column="1" Grid.Row="1"
                           FontSize="12" Foreground="#333" VerticalAlignment="Center" Text="—"/>
            </Grid>
        </GroupBox>

        <!-- 查询范围 -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="查询范围:" FontSize="12" Foreground="#555"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="LayerModeCombo" Grid.Column="1" Height="26"
                      FontSize="11" SelectedIndex="0"
                      SelectionChanged="OnLayerModeChanged">
                <ComboBoxItem Content="可见图层" Tag="Visible"/>
                <ComboBoxItem Content="顶部图层" Tag="Top"/>
                <ComboBoxItem Content="所有图层" Tag="All"/>
            </ComboBox>
        </Grid>

        <!-- 结果列表 -->
        <GroupBox Grid.Row="2" Header="像素值" Padding="10" Margin="0,0,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ResultList" FontSize="12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="#444"
                                           Text="{Binding LayerName}"/>
                                <ItemsControl ItemsSource="{Binding BandValues}"
                                              Margin="10,2,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="12" Foreground="#666"
                                                       Text="{Binding}" Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>

        <TextBlock x:Name="NoDataHint" Text="无数据"
                   FontSize="12" Foreground="#AAA" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Visibility="Collapsed"
                   Grid.Row="2"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="关闭" Width="70" Height="28" Click="OnCloseClick"
                    Background="#E5E7EB" Foreground="#333" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
